# ─────────────────────────────────────────
# ETYCONS — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# PostgreSQL database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/etycons

# Session secret — use a long random string (32+ characters)
SESSION_SECRET=replace_with_a_long_random_secret_string_here

# Admin dashboard password (access /admin)
ADMIN_PASSWORD=YourAdminPassword

# Email (SMTP) — for contact form notifications to info@etycons.com
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password

# OpenAI API key — for the AI chatbot
OPENAI_API_KEY=sk-your_openai_api_key_here

# Node environment — always production on the live server
NODE_ENV=production

# Port — Hostinger Node.js usually auto-sets this; default 5000
PORT=5000
